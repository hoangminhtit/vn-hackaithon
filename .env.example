HF_MODEL_ID=Qwen/Qwen3.5-4B
HF_LOCAL_DIR=model
LLM_MAX_NEW_TOKENS=32
LLM_ANSWER_MAX_TOKENS=64
LLM_USE_LLM_ROUTE=0
# Greedy (mặc định): LLM_DO_SAMPLE=0. Sampling: LLM_DO_SAMPLE=1 + LLM_TEMPERATURE + LLM_TOP_P
LLM_DO_SAMPLE=0
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
# RAG: overlap 25-50 từ giữa các chunk; query = câu hỏi (BM25)
RAG_CHUNK_MODE=overlap
RAG_CHUNK_WORDS=120
RAG_CHUNK_OVERLAP=40
RAG_BM25_TOP_K=12
RAG_BM25_MAX_CHARS=5500
# Passage dài hơn ngưỡng này → BM25 trước khi gửi LLM (mặc định 1500)
RAG_RETRIEVE_MIN_CHARS=1500